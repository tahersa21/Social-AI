# ================================================================
# Facebook AI Agent — متغيرات البيئة
# ================================================================
# انسخ هذا الملف إلى .env وعدِّل القيم قبل تشغيل المشروع
# Copy this file to .env and fill in the values before running
# ================================================================

# ─────────────────────────────────────────────────────────────
# [إلزامي] قاعدة البيانات — DATABASE
# يجب أن تكون PostgreSQL
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/facebook_agent

# ─────────────────────────────────────────────────────────────
# [إلزامي] المنافذ — PORTS
# يُضبَط تلقائياً من منصة الاستضافة في الغالب
# ─────────────────────────────────────────────────────────────
# API Server port
PORT=8080
# Dashboard base path (/ for root, /dashboard for sub-path)
BASE_PATH=/

# ─────────────────────────────────────────────────────────────
# [إلزامي] تشفير مفاتيح الـ AI — ENCRYPTION
# تحذير: إذا تغيرت هذه القيمة، كل مفاتيح الـ AI المخزَّنة تُفسَد
# أنشئها بـ: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-random-32-char-minimum-string-here

# ─────────────────────────────────────────────────────────────
# [موصى به] جلسات تسجيل الدخول — JWT
# إذا غاب: يُولَّد مفتاح عشوائي ويُحفَظ في ملف .jwt_secret
#           (الجلسات تبقى سليمة عبر الـ restarts، لكن المفتاح مرتبط بالجهاز)
# في الإنتاج: اضبط هذا المتغير صراحةً لضمان استمرار الجلسات عبر أي نشر جديد
# أنشئه بـ: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
JWT_SECRET=your-random-jwt-secret-here

# ─────────────────────────────────────────────────────────────
# [أمني] حساب المدير — ADMIN ACCOUNT
# يُطبَّق فقط عند أول تشغيل (إذا لم يوجد مدير في قاعدة البيانات)
# إذا غاب ADMIN_PASSWORD: يُولَّد تلقائياً ويُطبَّع في logs — اقرأه فور التشغيل!
# ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# ─────────────────────────────────────────────────────────────
# [إلزامي في الإنتاج] رابط التطبيق — APP URL
# يُستخدَم في: CORS + روابط الصور + HTTP-Referer لـ OpenRouter
# مثال: https://yourdomain.com
# ─────────────────────────────────────────────────────────────
APP_URL=https://your-domain.com

# ─────────────────────────────────────────────────────────────
# [اختياري] نطاقات CORS إضافية — EXTRA CORS ORIGINS
# مطلوب إذا كان الـ dashboard في نطاق مختلف عن الـ API
# قيم متعددة مفصولة بفواصل — بدون مسافة بعد الفاصلة
# ─────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=https://dashboard.yourdomain.com,https://app.yourdomain.com

# ─────────────────────────────────────────────────────────────
# [اختياري - موصى به في الإنتاج] Redis
# إذا غاب: يعمل بـ in-memory cache (يُصفَّر عند إعادة التشغيل)
# إذا وُجد: الـ cache + جلسات التسوق تبقى بعد restart
# ─────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# [اختياري] رابط API للـ dashboard — VITE API URL
# مطلوب فقط إذا كان الـ API في نطاق مختلف عن الـ dashboard
# إذا غاب: يستخدم window.location.origin تلقائياً
# ─────────────────────────────────────────────────────────────
# VITE_API_URL=https://api.yourdomain.com

# ─────────────────────────────────────────────────────────────
# [تلقائي - Replit فقط] لا تضبطها يدوياً في بيئات أخرى
# تُستخدَم كـ fallback إذا لم يُضبَط APP_URL
# ─────────────────────────────────────────────────────────────
# REPLIT_DOMAINS=  (auto-set by Replit)
# REPLIT_DEV_DOMAIN=  (auto-set by Replit)
# REPL_ID=  (auto-set by Replit)
